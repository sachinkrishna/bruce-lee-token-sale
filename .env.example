MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=xfee_sale

MASTER_WALLET_ADDRESS=
MASTER_WALLET_PRIVATE_KEY=
ROOT_CHILD_WALLET_ADDRESS=BRrtYftGhXBh3JcwmveuB4ZcskkYvUeLzNgPcf5VF6Ry
ROOT_CHILD_LEVEL=14
ROOT_CHILD_MAX_DIRECT_REFERRALS=1
# Enforce that master only refers the root child and the root child has at most
# ROOT_CHILD_MAX_DIRECT_REFERRALS direct referrals. Leave true in production.
ENFORCE_ROOT_CHILD=true

TREASURY_WALLET_ADDRESS=
TREASURY_WALLET_PRIVATE_KEY=

XFEE_TOKEN_MINT=
POOL_ADDRESS=

QUICKNODE_RPC_URL=
SOL_PRICE_API_URL=

# 1 XFEE = $1 USD (hard-coded). XFEE_TOTAL_SUPPLY is a display-only cap for /stats/global.
# Set to 0 (or any negative number) for an unlimited sale — tokens_remaining is reported as null.
XFEE_TOTAL_SUPPLY=0

PURCHASE_WALLET_EXPIRY_MINUTES=15
PURCHASE_MIN_USD=6.00
GAS_BUFFER_USD=5.00
LEAVE_IN_PURCHASE_WALLET_USD=4.50

# Admin API key — required for all /admin endpoints
ADMIN_API_KEY=

# Test mode — set to true to mock all Solana interactions
TEST_MODE=false
TEST_SOL_PRICE=150.00

# Set false to pause POWER staking while keeping purchases and commissions live
POWER_DISTRIBUTION_ENABLED=true

# Bonus multiplier for purchases made while POWER distribution was disabled.
# Example: 1.25 means a $100 purchase receives 2500 POWER instead of 2000.
POWER_DELAYED_STAKE_BONUS_MULTIPLIER=1.00

# Global pool — direct auto-settlement from the funding wallet (no on-chain program)
GLOBAL_POOL_ENABLED=true
GLOBAL_POOL_DURATION_DAYS=15
# How often the worker scans for pools whose 15-day window has ended.
GLOBAL_POOL_FINALIZE_INTERVAL_SECONDS=300
# Base58 64-byte secret key of the funding wallet (typically the master/top wallet).
# This wallet pays both the SOL payouts and the network fees.
GLOBAL_POOL_FUNDING_WALLET_PRIVATE_KEY=
# SOL reserve left in the funding wallet after settlement (covers network fees + safety).
GLOBAL_POOL_FUNDING_BUFFER_SOL=0.05
# How many user payouts to send in parallel from the funding wallet.
GLOBAL_POOL_SETTLEMENT_CONCURRENCY=3
# How many times to poll signature status before treating a tx as unconfirmed.
GLOBAL_POOL_CONFIRM_RETRIES=30
